---
layout: default
---
{% capture profile_display_name %}
  {{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %}{% if site.last_name %} {{ site.last_name }}{% endif %}
{% endcapture %}
{% if page.profile.align == 'center' %}
  <style>
    .about-profile-center {
      width: 100%;
      margin: 0 auto 1rem;
      text-align: center;
    }

    .about-profile-center picture {
      display: flex;
      justify-content: center;
      margin: auto;
    }

    .about-profile-center img {
      margin: auto;
      max-width: 25%;
      min-width: 100px;
    }

    .about-profile-center .header {
      margin-bottom: 1rem;
      font-size: x-large;
    }

    .about-profile-center .name {
      font-size: xx-large;
    }

    .about-profile-center .title {
      font-size: large;
      opacity: 75%;
    }

    .about-profile-center .address {
      margin-bottom: 0.25rem;
      font-family: monospace;
      font-size: large;
      opacity: 75%;
    }

    .about-profile-center .address p {
      display: inline-block;
      margin: auto;
    }

    .about-profile-center .contact-icons {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      margin-top: 0.35rem;
    }

    .about-profile-center .contact-icons a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.7rem;
      height: 1.7rem;
      border: 1px solid transparent;
      border-radius: 0.3rem;
      color: var(--global-text-color);
      line-height: 1;
      text-decoration: none;
      transition:
        background-color 160ms ease,
        border-color 160ms ease,
        color 160ms ease;
    }

    .about-profile-center .contact-icons a:hover {
      border-color: var(--global-theme-color);
      background-color: color-mix(in srgb, var(--global-theme-color) 10%, transparent);
      color: var(--global-theme-color);
      text-decoration: none;
    }

    .about-profile-center .contact-icons i {
      font-size: 1.25rem;
      line-height: 1;
    }

    .about-profile-center .contact-icons .ai-cv {
      font-size: 1.42rem;
      transform: translateY(0.07rem);
    }

    @media (max-width: 576px) {
      .about-profile-center img {
        min-width: 200px;
      }
    }
  </style>
{% endif %}

{% if page.one_page_nav %}
  <style>
    html {
      scroll-behavior: smooth;
    }

    #about,
    .one-page-section {
      scroll-margin-top: 5.75rem;
    }

    .one-page-section {
      margin-top: 3.25rem;
      padding-top: 2.25rem;
      border-top: 1px solid var(--global-divider-color);
    }

    .one-page-section h2 {
      margin-bottom: 1rem;
    }

    .publications h2.bibliography,
    .teaching-separator {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      width: 80%;
      margin: 2.25rem auto 1.25rem;
      padding-top: 0;
      border-top: 0;
      color: #b3b7bb;
      font-family: inherit;
      font-size: 1.5rem;
      font-weight: 350;
      line-height: 1.2;
      text-align: center;
    }

    .publications h2.bibliography::before,
    .publications h2.bibliography::after,
    .teaching-separator::before,
    .teaching-separator::after {
      content: "";
      flex: 1 1 auto;
      border-top: 1px solid var(--global-divider-color);
    }

    .publications ol.bibliography li .author > em {
      border-bottom: 0;
      font-style: normal;
      font-weight: 700;
    }

    .publications ol.bibliography li > .row {
      border-left: 3px solid transparent;
      border-radius: 4px;
      margin-left: 0;
      margin-right: 0;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .publications ol.bibliography li .row.first-author-publication {
      background-color: var(--global-code-bg-color);
      border-left-color: var(--global-theme-color);
      padding-bottom: 1rem;
      padding-top: 1rem;
    }

    .publications ol.bibliography li .title .publication-title-translation {
      display: block;
      margin-top: 0.15rem;
      color: var(--global-text-color-light);
      font-size: 0.9rem;
      font-weight: 400;
    }

    .publications ol.bibliography li .abbr abbr {
      color: #fff !important;
    }

    .publications ol.bibliography li .abbr abbr a {
      color: #fff;
    }

    .publications ol.bibliography li .links {
      margin-top: 0.45rem;
    }

    .publications ol.bibliography li .links a.btn {
      border: 0;
      margin: 0 1rem 0 0;
      padding: 0;
      color: var(--global-theme-color);
      font-size: 0.9rem;
      line-height: 1.4;
    }

    .publications ol.bibliography li .links a.btn:hover {
      border: 0;
      color: var(--global-hover-color);
      text-decoration: underline;
    }

    @media (prefers-reduced-motion: reduce) {
      html {
        scroll-behavior: auto;
      }
    }
  </style>
{% endif %}

<div class="post" {% if page.one_page_nav %}id="about" data-one-page-section="about"{% endif %}>
  {% unless page.profile.align == 'center' %}
    <header class="post-header">
      <h1 class="post-title">
        {{ profile_display_name | strip }}
      </h1>
      <p class="desc">{{ page.subtitle }}</p>
    </header>
  {% endunless %}

  <article>
    {% if page.profile %}
      {% if page.profile.align == 'center' %}
        <div class="profile about-profile-center">
          {% if page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class alt=page.profile.image cache_bust=true %}
          {% endif %}

          <div class="header">
            <div class="name">
              {{ profile_display_name | strip }}
            </div>
            {% if page.profile.title %}
              <div class="title">{{ page.profile.title }}</div>
            {% endif %}
            {% if page.profile.address %}
              <div class="address">{{ page.profile.address }}</div>
            {% endif %}
            {% if page.profile.links %}
              <div class="contact-icons">
                {% for link in page.profile.links %}
                  {% assign profile_link_url = link.url | default: '#' %}
                  {% assign profile_link_url_lower = profile_link_url | downcase %}
                  {% assign profile_link_target_attrs = '' %}
                  {% if profile_link_url_lower contains '.pdf' %}
                    {% assign profile_link_target_attrs = ' target="_blank" rel="noopener noreferrer"' %}
                  {% endif %}
                  <a href="{{ profile_link_url }}" title="{{ link.title }}" aria-label="{{ link.title }}"{{ profile_link_target_attrs }}>
                    <i class="{{ link.icon }}"></i>
                  </a>
                {% endfor %}
              </div>
            {% endif %}
            {% if page.social %}
              <div class="contact-icons">{% social_links %}</div>
              <div class="contact-note">{{ site.contact_note }}</div>
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
          {% if page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
            {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image cache_bust=true %}
          {% endif %}
          {% if page.profile.more_info %}
            <div class="more-info">{{ page.profile.more_info }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/research/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if page.social and page.profile.align != 'center' %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% if site.plugins contains 'al_newsletter' %}
        {% include plugins/al_newsletter_form_center_margin.liquid %}
      {% else %}
        {% include newsletter.liquid center=true %}
      {% endif %}
    {% endif %}
  </article>
</div>

{% if page.one_page_nav %}
  <script defer src="{{ '/assets/js/one-page-nav.js' | relative_url | bust_file_cache }}"></script>
{% endif %}
